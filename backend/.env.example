# Copy to .env and fill in your values

# Application
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-string

# Database — Supabase connection string (Session mode, port 5432)
DATABASE_URL=postgresql+psycopg2://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# Redis (local dev: redis://localhost:6379/0)
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# RAWG API — register at https://rawg.io/apidocs
RAWG_API_KEY=your-rawg-api-key-here
RAWG_BASE_URL=https://api.rawg.io/api

# LLM provider — uncomment the one you use
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Rate limits (SlowAPI format: "N/period")
RATE_LIMIT_BASIC=30/minute
RATE_LIMIT_PREMIUM=100/minute
RATE_LIMIT_ADMIN=200/minute

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=["http://localhost:5173"]
