APP_ENV=production
APP_RUNTIME=lambda
TASK_BACKEND=sqs
KV_BACKEND=dynamodb

AWS_REGION=ap-southeast-1
AWS_SSM_PARAMETER_PATH=/gamerec/prod
DYNAMODB_KV_TABLE=video-game-recommender-KvTable
SQS_RECOMMENDATION_QUEUE_URL=https://sqs.ap-southeast-1.amazonaws.com/account/recommendation
SQS_AI_QUEUE_URL=https://sqs.ap-southeast-1.amazonaws.com/account/ai
SQS_HLTB_QUEUE_URL=https://sqs.ap-southeast-1.amazonaws.com/account/hltb
SQS_RAWG_QUEUE_URL=https://sqs.ap-southeast-1.amazonaws.com/account/rawg

ECS_CLUSTER_ARN=arn:aws:ecs:ap-southeast-1:account:cluster/video-game-recommender
ECS_RAWG_TASK_DEFINITION_ARN=arn:aws:ecs:ap-southeast-1:account:task-definition/video-game-recommender-rawg:1
ECS_RAWG_CONTAINER_NAME=rawg
ECS_SUBNET_IDS=subnet-abc123,subnet-def456
ECS_SECURITY_GROUP_IDS=sg-abc123

RAWG_MONTHLY_REQUEST_BUDGET=15000
RAWG_RECENT_REQUEST_BUDGET=1000
RAWG_DETAIL_REFRESH_REQUEST_BUDGET=500
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

ALLOWED_ORIGINS=https://app.yourdomain.com
COOKIE_DOMAIN=.yourdomain.com
COOKIE_SAMESITE=lax
